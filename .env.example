PORT=4002
# CORS - Origens confiáveis separadas por vírgula (deixe vazio para permitir todas as origens em ambiente de teste)
CORS_ALLOWED_ORIGINS=
# Integracao Zabbix
ZABBIX_URL=
ZABBIX_TOKEN=
# Habilitar simulador local caso a conexao Zabbix esteja indisponivel
ENABLE_SIMULATION=false

# Telegram NOC alerts
NOC_SHARED_BOT_ENV_PATH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_PRIORITY=P3
NOC_PUBLIC_URL=

# Validações e Confirmações (ciclos de 12 segundos)
LINK_DOWN_CONFIRMATIONS=3
LINK_UP_CONFIRMATIONS=2

# Supabase Backup Config
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=
